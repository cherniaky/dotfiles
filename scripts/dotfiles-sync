#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/dotfiles"

cd "$DOTFILES_DIR"

if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  echo "No changes to sync."
  exit 0
fi

git add -A
git commit -m "dotfiles: auto-sync $(date '+%Y-%m-%d %H:%M')"
git push
echo "Dotfiles synced."
