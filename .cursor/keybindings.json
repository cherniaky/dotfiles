// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+shift+e ctrl+shift+e",
        "command": "actions.findWithSelection"
    },
    {
        "key": "alt+cmd+z alt+cmd+z",
        "command": "workbench.files.action.focusOpenEditorsView",
        "when": "workbench.explorer.openEditorsView.active"
    },
    {
        "key": "shift+cmd+v shift+cmd",
        "command": "editor.action.toggleScreenReaderAccessibilityMode",
        "when": "accessibilityHelpIsShown"
    },
    {
        "key": "cmd+e",
        "command": "workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "shift+cmd+e",
        "command": "-workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "cmd+e",
        "command": "-actions.findWithSelection"
    },
    {
        "key": "cmd+e",
        "command": "-editor.action.toggleScreenReaderAccessibilityMode",
        "when": "accessibilityHelpIsShown"
    },
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    },
    {
        "key": "alt+cmd+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },
    
]
